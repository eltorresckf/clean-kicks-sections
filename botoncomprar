<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #000;
}

.cta-container {
  max-width: 900px;
  margin: 0 auto;
  padding: 30px 20px;
  text-align: center;
  color: #fff;
}

.cta-text {
  font-size: 18px;
  margin-bottom: 20px;
  opacity: 0.9;
}

.cta-button {
  display: inline-block;
  background: #fff;
  color: #000;
  font-size: 18px;
  font-weight: bold;
  padding: 16px 30px;
  border-radius: 12px;
  text-decoration: none;
  transition: all 0.3s ease;
  cursor: pointer;
}

.cta-button:hover {
  background: #ddd;
  transform: scale(1.05);
}

.cta-subtext {
  font-size: 14px;
  margin-top: 12px;
  opacity: 0.7;
}
</style>
</head>

<body>

<div class="cta-container">
  
  <div class="cta-text">
    Dale a tus tenis el cuidado que merecen 👇
  </div>

  <div class="cta-button" onclick="scrollToBuy()">
    Comprar ahora
  </div>

  <div class="cta-subtext">
    Compra segura • Envíos a todo México 🇲🇽
  </div>

</div>

<script>
function scrollToBuy() {
  const botones = document.querySelectorAll('button, a');

  for (let btn of botones) {
    if (btn.innerText.toLowerCase().includes('agregar') || 
        btn.innerText.toLowerCase().includes('comprar')) {
      
      btn.scrollIntoView({ behavior: 'smooth', block: 'center' });
      btn.click();
      return;
    }
  }

  alert("No se encontró el botón de compra");
}
</script>

</body>
</html>
